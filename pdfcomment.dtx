% \subsection{\cs{pdfmargincomment}}
% The marginnote is patched above. 
%    \begin{macrocode}
\newcommand{\pdfmargincomment}[2][]%
{%
  \ifhmode\unskip\fi%
  \ifvmode\leavevmode\fi%
  % Copy all global options to local options
  \group_begin:
  %\pc@copy@gopt@lopt%
  \gdef\pc@collect@PDFOBJID{S}
  % Change local options if specified
  \keys_set:nn{pdfcomment}{#1}
%    \end{macrocode}
% Encode Contents, Author and Subject 
 % and transform color input to pdf color
%    \begin{macrocode}
  \pc@encode@PDF{#2}%  
  \pc@encode@colors
  \ifpc@gopt@final\else%
    \ifpc@lopt@disable\else%
      \hspace*{0pt}%
      \pc@create@lpc%
      \@@_dict_store_color:
      \@@_dict_store_dates:
      \@@_dict_store_text:      
      % center marginnotes!
        \renewcommand{\raggedleftmarginnote}{\pc@raggedleftmarginnote}%
        \renewcommand{\raggedrightmarginnote}{\pc@raggedrightmarginnote}%
        % typeset text annotation (see: PDF Reference)
        \marginnote%
        {%
            \vbox%
            {\tagpdfparaOff%
              \hsize=0pt%
              \noindent%
              \vspace{\pc@lopt@voffset}%
              \hbox to 0pt%
              {%
                \vsize=0pt%
                \hskip\pc@lopt@hoffset%
                \UseTaggingSocket{pdfcomment/annot}
                {}
                {\pdfannot_widget_box:nnn{\normalbaselineskip}{\normalbaselineskip}{0pt}}
                \@@_collect_objid:
                \@@_save_objid:
                \hss%
              }%
            }%
          \hspace{\pc@lopt@hspace}%
        }%     
    \fi%
  \fi%  
  \group_end:
}%

%    \end{macrocode}
