\newcommand{\pdfreply}[2][]
 {
  \ifhmode\unskip\fi
  \ifvmode\leavevmode\fi
  \group_begin:  
  \gdef\pc@collect@PDFOBJID{S}
  \keys_set:nn{pdfcomment}{#1}
  \def\pc@lopt@subtype{/Text}
%    \end{macrocode}
% Encode Contents, Author and Subject 
% and transform color input to pdf color
%    \begin{macrocode}
  \pc@encode@PDF{#2}
  \ifpc@gopt@final\else
    \ifpc@lopt@disable\else
      \hspace*{0pt}%
      %\pc@create@lpc% ????????
      % typeset text annotation (see: PDF Reference)
%    \end{macrocode}
% TODO: check logic
%    \begin{macrocode}
      \xdef\pc@zref@PDFOBJID{\pc@get@PDFOBJID{\pc@lopt@replyto}}      
      \clist_map_inline:Nn \pc@zref@PDFOBJID
        {
         \str_if_eq:eeTF{##1}{A}
          {            
            \xdef\pc@collect@PDFOBJID{\pc@collect@PDFOBJID,A}
          }
          {
           \str_if_eq:eeF{##1}{S}            
            {
              \pdfdict_put:nnn {l_@@_text_dict}  {IRT}{##1}
              \vbox
