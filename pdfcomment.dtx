\newcommand{\pdfcomment}[2][]
 {
   \ifhmode\unskip\fi
   \ifvmode\leavevmode\fi
%    \end{macrocode}
% TODO Check if the command needs to be set globally!
%    \begin{macrocode}
   \group_begin:
