\pdfdict_new:n{l_@@_sideline_dict}
\newenvironment{pdfsidelinecomment}[2][]%
{
  \ifhmode\unskip\fi
  \ifvmode\leavevmode\fi
  \gdef\pc@collect@PDFOBJID{S}
  \keys_set:nn{pdfcomment}{#1}
%    \end{macrocode}
% Encode Contents, Author and Subject 
% and transform color input to pdf color
%    \begin{macrocode}
  \pc@encode@PDF{#2}%
  \pc@encode@colors
  \pdfdict_put:nne {l_@@_sideline_dict} {Subtype} {/Line}
  \tl_if_empty:eF{\pc@lopt@color} 
   {
     \pdfdict_put:nne {l_@@_sideline_dict} {C}{[\pc@hyenc@color]}
   }
  \tl_if_empty:eF{\pc@lopt@icolor} 
   {
     \pdfdict_put:nne {l_@@_sideline_dict} {IC}{[\pc@hyenc@icolor]}
   } 
  \pdfdict_put:nne {l_@@_sideline_dict} {CreationDate} {(\pc@lopt@date)}
  \pdfdict_put:nne {l_@@_sideline_dict} {M} {(\pc@lopt@date)}    
  \pdfdict_put:nne {l_@@_sideline_dict} {LE} {[\pc@lopt@linebegin\space\pc@lopt@lineend]}
  \str_if_eq:eeTF{\pc@lopt@caption}{none}%
    {
      \pdfdict_put:nne {l_@@_sideline_dict} {Cap} {false}
    }
    {
     \pdfdict_put:nne {l_@@_sideline_dict} {Cap} {true}
     \pdfdict_put:nne {l_@@_sideline_dict} {CP}{/\pc@lopt@caption}
    } 
   \pdfdict_put:nne {l_@@_sideline_dict} 
      {CO}
      {[\pc@lopt@captionhoffset\space \pc@lopt@captionvoffset]}
   
   \pdfdict_put:nne {l_@@_sideline_dict} {CA} {\pc@lopt@opacity}
   \pdfdict_put:nne {l_@@_sideline_dict} {T} {(\pc@pdfenc@author)}
   \pdfdict_put:nne {l_@@_sideline_dict} {Subj} {(\pc@pdfenc@subject)}
   \pdfdict_put:nne {l_@@_sideline_dict} {Contents} {(\pc@pdfenc@contents)}
   \pdfdict_put:nne {l_@@_sideline_dict} {F} {4}
   \pdfdict_put:nne {l_@@_sideline_dict} {BS} 
    {
     <</W~\pc@lopt@linewidth\space
       /S~/\pc@lopt@borderstyle\space
       /D~[\pc@lopt@dashstyle]\space
     >>
    }
   \pdfdict_put:nne {l_@@_sideline_dict} {BE} 
    {<</S~/\pc@lopt@bse\space/I~\pc@lopt@bsei>>} 
   
  \zsavepos{pdfcomment:slc:\thepc@count@iv}
  \zref@refused{pdfcomment:slc:\thepc@count@iv}
  \setlength{\pc@Sposx}{\zposx{pdfcomment:slc:\thepc@count@iv}sp}
  \setlength{\pc@Sposy}{\zposy{pdfcomment:slc:\thepc@count@iv}sp}
  \stepcounter{pc@count@iv}
  \setlength{\pc@Eposx}{\zposx{pdfcomment:slc:\thepc@count@iv}sp}
  \setlength{\pc@Eposy}{\zposy{pdfcomment:slc:\thepc@count@iv}sp}
  \settoheight{\pc@box@height}{Tq}
  \settoheight{\pc@box@depth}{Tq}
  \stepcounter{pc@count@i}
  \label{pdfcomment:pageS:\thepc@count@i}
