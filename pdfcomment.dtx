\newcommand{\pc@calc@textblockpos}
 {
  \if@twoside
    \stepcounter{pc@count@ii}
    \label{pdfcomment:ts:page:\thepc@count@ii}
    \refused{pdfcomment:ts:page:\thepc@count@ii}
