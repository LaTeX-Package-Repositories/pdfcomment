                      {0pt}
                      {\normalbaselineskip}
                      {0pt}
                      {
                        \pdfdict_use:n{l_@@_text_dict}
                        \pdfdict_use:n {l_@@_markup_dict}
                      }
                   }
                  \@@_collect_objid:
                  \hss
                }
              }
            }
          }
        }
        \@@_save_objid:
    \fi
  \fi
  \group_end:
}
